# JOSINT env template.
# Copy to .env and fill in real values. .env is gitignored.

# MiniMax text extraction / fallback labeling.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_TEXT_MODEL=MiniMax-M2.7-highspeed

# MiniMax reasoning model for hidden-employer inference.
MINIMAX_REASONING_API_KEY=
MINIMAX_REASONING_BASE_URL=https://api.minimaxi.com/v1/chat/completions
MINIMAX_REASONING_MODEL=MiniMax-M3
MINIMAX_REASONING_THINKING_TYPE=adaptive
MINIMAX_REASONING_SPLIT=true

# Metaso live search for evidence gathering and employer verification.
METASO_API_KEY=
METASO_BASE_URL=https://metaso.cn
METASO_MODEL=fast

# Optional Feishu Bitable / IM integration for OpenClaw or server cron.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_NOTIFY_OPEN_ID=

# Optional runtime knobs.
JOSINT_REPORT_PREFIX=josint
JOSINT_TIMEZONE=Asia/Shanghai
